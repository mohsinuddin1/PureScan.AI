---
export function getStaticPaths() {
  const locales = ["ar","ar-MA","cs","da","de","el","es","fi","fr","hu","it","ja","ko","lt","lv","nb","nl","no","pl","pt","ro","ru","sv","tr","zh"];
  return locales.map(lang => ({ params: { lang } }));
}

import { getTranslations } from '../../lib/i18n-utils';
import Layout from '../../layouts/Layout.astro';
import Support from '../../components/Support.jsx';
const lang = Astro.currentLocale || 'en';
const translations = await getTranslations(lang);
import { SupportIsland } from '../../components/Islands.jsx';
---
<Layout title="Support - PureScan AI">
  <SupportIsland client:load  lang={lang} translations={translations} />
</Layout>
