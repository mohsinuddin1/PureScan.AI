---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, getEntry, render } from 'astro:content';
import LanguageSwitcher from '../../../components/LanguageSwitcher.jsx';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const slugs = new Set(posts.map(p => p.id.split('/')[1]));
  const locales = ["ar","ar-MA","cs","da","de","el","es","fi","fr","hu","it","ja","ko","lt","lv","nb","nl","no","pl","pt","ro","ru","sv","tr","zh"];
  const paths = [];
  for (const lang of locales) {
      for (const s of slugs) {
          paths.push({ params: { lang, slug: s } });
      }
  }
  return paths;
}

const lang = Astro.currentLocale || 'en';
const { slug } = Astro.params;

let post = await getEntry('blog', `${lang}/${slug}`);
if (!post) {
  post = await getEntry('blog', `en/${slug}`);
}

if (!post) {
  return new Response(null, { status: 404, statusText: 'Not found' });
}

const { Content } = await render(post);

// Build the blog slug map for language switching
// Uses the numeric id in frontmatter to find the equivalent blog in each language
const blogId = post.data.id;
const allPosts = await getCollection('blog');
const blogSlugMap = {};
for (const p of allPosts) {
  if (p.data.id === blogId) {
    const pLang = p.id.split('/')[0];
    const pSlug = p.id.split('/')[1];
    blogSlugMap[pLang] = pSlug;
  }
}

// Build related articles from English posts with the same badge (max 3, excluding current)
const enPosts = allPosts.filter(p => p.id.startsWith('en/') && p.data.id !== blogId);
const sameBadge = enPosts.filter(p => p.data.badge === post.data.badge);
const otherPosts = enPosts.filter(p => p.data.badge !== post.data.badge);
const relatedPosts = [...sameBadge, ...otherPosts].slice(0, 3).map(p => ({
  title: p.data.title,
  slug: p.id.split('/')[1],
  badge: p.data.badge,
}));

// Stable publish date: use frontmatter publishDate, or derive from blog id
const publishDate = post.data.publishDate || '2025-06-01';

// Canonical URL for this page
const siteUrl = 'https://purescan.droploop.in';
const canonicalPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonicalUrl = new URL(canonicalPath, siteUrl).href;
---

<Layout title={post.data.title} description={post.data.description} image={post.data.image}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Article",
        "headline": post.data.title,
        "description": post.data.description,
        "image": post.data.image,
        "isAccessibleForFree": true,
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonicalUrl
        },
        "author": {
          "@type": "Organization",
          "name": "PureScan AI",
          "url": "https://purescan.droploop.in/",
          "logo": {
            "@type": "ImageObject",
            "url": "https://purescan.droploop.in/logo.png"
          }
        },
        "publisher": {
          "@id": "https://purescan.droploop.in/#organization"
        },
        "datePublished": publishDate,
        "dateModified": publishDate,
        "inLanguage": lang,
        "speakable": {
          "@type": "SpeakableSpecification",
          "cssSelector": ["article", "h1", ".prose h3", ".prose p"]
        }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://purescan.droploop.in/"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Blog",
            "item": "https://purescan.droploop.in/blog"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": post.data.title
          }
        ]
      }
    ]
  })} />
  <div class="min-h-screen bg-slate-50 text-slate-900 font-sans antialiased selection:bg-slate-200" dir={lang === 'ar' || lang === 'ar-MA' ? 'rtl' : 'ltr'}>
    <nav class="w-full bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-slate-200">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <a href={lang === 'en' ? '/blog' : `/${lang}/blog`} class="text-slate-400 hover:text-slate-900 transition-colors flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                    <span class="text-sm font-medium hidden sm:inline">Back</span>
                </a>
            </div>
            <div class="flex items-center gap-2 cursor-pointer">
                <img src="/logo.png" alt="PureScan AI" class="w-5 h-5 object-contain" />
                <span class="font-semibold tracking-tight text-sm hidden sm:inline">PureScan AI Blog</span>
            </div>
            <div class="flex items-center">
                <LanguageSwitcher client:load currentLang={lang} blogSlugMap={blogSlugMap} />
            </div>
        </div>
    </nav>

    <main class="px-5 py-12 md:py-20 max-w-5xl mx-auto min-h-[70vh]">
      <div class="bg-white rounded-[2rem] sm:rounded-[3rem] p-6 sm:p-12 md:p-16 shadow-xl border border-slate-100 max-w-4xl mx-auto relative overflow-hidden">
        
        <a href={lang === 'en' ? '/blog' : `/${lang}/blog`} class="flex items-center gap-2 text-slate-400 hover:text-slate-900 font-bold mb-10 transition-colors w-fit group">
            <svg class="w-5 h-5 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            Back to all articles
        </a>

        <div class="mb-10 max-w-3xl">
            <span class="inline-block bg-emerald-50 px-3 py-1 rounded-full text-sm font-bold text-emerald-600 mb-6 border border-emerald-100">
                {post.data.badge}
            </span>
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900 leading-[1.15]">
                {post.data.title}
            </h1>
        </div>

        <div class="w-full h-[300px] sm:h-[450px] rounded-3xl overflow-hidden mb-12 shadow-sm border border-slate-100">
            <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover" />
        </div>

        <article class="max-w-3xl mx-auto">
            <Content />
        </article>

        {/* Related Articles — Internal Linking for SEO */}
        {relatedPosts.length > 0 && (
          <div class="max-w-3xl mx-auto mt-16 pt-10 border-t border-slate-200">
            <h3 class="text-lg font-bold text-slate-900 mb-6">Related Articles</h3>
            <div class="grid gap-4 sm:grid-cols-3">
              {relatedPosts.map(rp => (
                <a href={lang === 'en' ? `/blog/${rp.slug}` : `/${lang}/blog/${rp.slug}`} class="block p-4 rounded-2xl border border-slate-100 hover:border-emerald-200 hover:bg-emerald-50/50 transition-all group">
                  <span class="inline-block text-xs font-semibold text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-full mb-2 border border-emerald-100">{rp.badge}</span>
                  <p class="text-sm font-semibold text-slate-800 leading-snug group-hover:text-emerald-700 transition-colors line-clamp-3">{rp.title}</p>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </main>

    <footer class="py-12 bg-white border-t-2 border-slate-100">
        <div class="max-w-7xl mx-auto px-6 text-center">
          <div class="flex justify-center items-center gap-2 mb-6">
            <img src="/logo.png" alt="PureScan AI" class="w-8 h-8 object-contain grayscale opacity-50" />
            <span class="font-extrabold tracking-tight text-xl italic text-slate-300">PureScan AI</span>
          </div>
          <p class="text-slate-500 font-medium pb-4 text-sm flex flex-wrap justify-center items-center gap-y-2">
            <a href="/grading" class="hover:text-[#17C37B] transition-colors">Grading System</a>
            <span class="mx-3 hidden md:inline">•</span>
            <a href="/blog" class="hover:text-[#17C37B] transition-colors ml-3 md:ml-0">Blog</a>
            <span class="mx-3">•</span>
            <a href="/privacy" class="hover:text-[#17C37B] transition-colors">Privacy Policy</a>
            <span class="mx-3">•</span>
            <a href="/terms" class="hover:text-[#17C37B] transition-colors">Terms of Service</a>
            <span class="mx-3">•</span>
            <a href="/support" class="hover:text-[#17C37B] transition-colors">Support</a>
          </p>
          <p class="text-slate-400 font-medium text-xs">&copy; {new Date().getFullYear()} PureScan AI. The Most Advanced Food & Cosmetic Scanner.</p>
        </div>
    </footer>
  </div>
</Layout>
