---
export function getStaticPaths() {
  const locales = ["bg","ar","ar-MA","cs","da","de","el","es","fr","it","ja","ko","lt","lv","nb","nl","no","pl","pt","ro","ru","sv","tr","zh"];
  return locales.map(lang => ({ params: { lang } }));
}

import { getTranslations } from '../../lib/i18n-utils';
import Layout from '../../layouts/Layout.astro';
import Grading from '../../components/Grading.jsx';
const lang = Astro.currentLocale || 'en';
const translations = await getTranslations(lang);
import { GradingIsland } from '../../components/Islands.jsx';
---
<Layout title="Grading - PureScan AI">
  <GradingIsland client:load  lang={lang} translations={translations} />
</Layout>
