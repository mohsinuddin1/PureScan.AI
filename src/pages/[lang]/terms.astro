---
export function getStaticPaths() {
  const locales = ["bg","ar","ar-MA","cs","da","de","el","es","fr","it","ja","ko","lt","lv","nb","nl","no","pl","pt","ro","ru","sv","tr","zh"];
  return locales.map(lang => ({ params: { lang } }));
}

import { getTranslations } from '../../lib/i18n-utils';
import Layout from '../../layouts/Layout.astro';
import TermsOfService from '../../components/Terms.jsx';

const lang = Astro.currentLocale || 'en';
const translations = await getTranslations(lang);
import { TermsIsland } from '../../components/Islands.jsx';
---
<Layout title="Terms of Service - PureScan AI">
  <TermsIsland client:load  lang={lang} translations={translations} />
</Layout>
